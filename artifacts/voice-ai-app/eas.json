{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ELEVENLABS_KEY": "SET_IN_EAS_SECRETS",
        "EXPO_PUBLIC_FIREBASE_API_KEY": "SET_IN_EAS_SECRETS"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ELEVENLABS_KEY": "SET_IN_EAS_SECRETS",
        "EXPO_PUBLIC_FIREBASE_API_KEY": "SET_IN_EAS_SECRETS"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ELEVENLABS_KEY": "SET_IN_EAS_SECRETS",
        "EXPO_PUBLIC_FIREBASE_API_KEY": "SET_IN_EAS_SECRETS"
      }
    }
  },
  "submit": {
    "production": {}
  }
}